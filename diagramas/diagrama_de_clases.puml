@startuml name diagrama de clases

enum tipoTransaccion{
    COMPRA
    VENTA
}

abstract class User{
    - usuario: string
    - contraseña: string
    + iniciarSesion(): void
}

interface Registrar{
    + registrar(): void
}

class Inversor extends User{
    - saldoVirtual: number
    - portafolio: Portafolio
    - saldoCaucionado: number

    - validarTarjeta(tarjeta: number, fechaVencimiento: Date, cvc: number): void
    ' + comprarActivos(activo: Activo, cantidad: number): void
    ' + venderActivos(activo: Activo, cantidad: number): void
    + consultarPortafolio(): Portafolio
    + ingresarFondos(monto: number, tarjeta: number, fechaVencimiento: Date, cvc: number): void
    + colocarCaucion(monto: number, dias: number): void
    + getters()
}

class Administrador extends User{
    + crearActivo(nombre: string, precio: number): Activo
    + modificarActivo(activo: Activo): void
    + eliminarActivo(activo: Activo): void
    + listarUsuarios(): Inversor[]
}

class Portafolio{
    - transacciones: Transaccion[]
    - tenenciaActivo: TenenciaActivo[]
    - valorPortafolio: number

    + getGananciaPerdida(): number
    + getHistorial(): Operacion[]
    + getters()
}

class TenenciaActivo{
    - cantidad: number
    - activo: Activo
}

class Activo{
    - id: number
    - nombre: string
    - ticker: string
    - precio: number
    - precioInicial: number
    - variacion: number
    - transacciones: Transaccion[]
    + getPrecioActual(): number
    + getVariacionDiaria(): number
    + getters()
}

class Transaccion{
    - id: number
    - ticker: string
    - tipo: tipoTransaccion
    - cantidad: number
    - precioEjecutado: number
    - fecha: Date
    + getters()
}

class Simulador{
    - activos: Activo[]
    - url: string[]

    - realizarCompra(activo: Activo):void
    - realizarVenta(activo: Activo):void
    + Simular(): Activo
}

class Sistema{
    + procesarCompra(activoId:number,cantidad:number,usuarioId:number)
    + comprarActivos(activo:Activo,cantidad:number,inversor:Inversor)
    + venderActivos(activo:Activo,cantidad:number,inversor:Inversor)
}


